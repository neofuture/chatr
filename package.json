{
  "name": "chatr-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Chatr monorepo - Real-time messaging platform",
  "scripts": {
    "prepare": "is-ci || node scripts/install-hooks.js",
    "test": "npm run test:frontend && npm run test:backend && npm run test:widget",
    "test:widget": "cd backend && npx jest --config ../widget-src/jest.config.js --rootDir ../widget-src",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "test:export": "npm run test:export:frontend && npm run test:export:backend && npm run test:export:e2e",
    "test:export:frontend": "cd frontend && npm run test:export",
    "test:export:backend": "cd backend && npm run test:export",
    "test:export:e2e": "node scripts/cache-e2e-results.js",
    "widget:build": "node widget-src/build.js",
    "widget:watch": "node widget-src/build.js --watch",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "terser": "^5.39.0"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "framer-motion": "^12.34.1"
  }
}
