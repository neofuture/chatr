{
  "name": "chatr-backend",
  "version": "0.1.1",
  "description": "Chatr backend API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --ignore=../node_modules --ignore=node_modules src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:export": "node src/scripts/export-test-results.js",
    "cleanup-images": "node src/scripts/cleanup-images.js",
    "generate-docs": "node src/scripts/generate-api-docs.js",
    "debug-auth": "node src/scripts/debug-websocket-auth.js",
    "seed:users": "ts-node --project tsconfig.seed.json prisma/seed-test-users.ts",
    "seed:bot": "ts-node -r tsconfig-paths/register --project tsconfig.seed.json prisma/seed-ai-bot.ts",
    "seed:support": "ts-node --project tsconfig.seed.json prisma/seed-support-user.ts",
    "cleanup:e2e": "ts-node --project tsconfig.seed.json prisma/cleanup-e2e.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/lib-storage": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "@prisma/client": "^5.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-streams-adapter": "^0.3.0",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.0",
    "mailtrap": "^4.4.0",
    "multer": "^2.0.2",
    "music-metadata": "^11.12.1",
    "openai": "^6.27.0",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^9.1.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.2",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.6",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.31.1",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "eslint": "^9.39.4",
    "jest": "^30.2.0",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript-eslint": "^8.57.0"
  }
}
