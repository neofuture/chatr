PORT=3001
PRODUCT_NAME=Chatr
DATABASE_URL=postgresql://chatr_user:chatr_password@localhost:5432/chatr
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your_super_secret_jwt_key_change_in_production
NODE_ENV=development

# Connection pool tuning (applied automatically by src/lib/prisma.ts)
# DATABASE_POOL_SIZE=20     # connections per Node.js instance (default 20)
# DATABASE_POOL_TIMEOUT=10  # seconds to wait for a free connection (default 10)

