PORT=3001
PRODUCT_NAME=Chatr
DATABASE_URL=postgresql://chatr_user:chatr_password@localhost:5432/chatr
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your_super_secret_jwt_key_change_in_production
NODE_ENV=development

# ── Email (Mailtrap) ─────────────────────────────────
# Without this, verification codes are logged to the console.
# Sign up free at https://mailtrap.io
# MAILTRAP_API_KEY=your_api_token
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
# MAIL_FROM_NAME=Chatr
# CONTACT_EMAIL=you@example.com

# ── SMS (SMS Works) ──────────────────────────────────
# SMS is suppressed in dev by default. Set ENABLE_SMS=1 to send real SMS.
# ENABLE_SMS=1
# SMS_WORKS_JWT=your_jwt_token
# DEV_PHONE=+447700000000

# ── AI (OpenAI) ──────────────────────────────────────
# Powers Luna chatbot and conversation summaries.
# Without this, Luna is disabled — everything else works.
# OPENAI_API_KEY=sk-your-key

# ── File Storage (AWS S3 — production only) ──────────
# In development, files are stored locally at backend/uploads/.
# S3_BUCKET=your-bucket
# AWS_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=your-secret

# ── Dashboard ────────────────────────────────────────
# Password-protect the dashboard test runner in production.
# DASHBOARD_TEST_PASSWORD=your_password_here

# ── Connection pool tuning ───────────────────────────
# DATABASE_POOL_SIZE=20
# DATABASE_POOL_TIMEOUT=10
