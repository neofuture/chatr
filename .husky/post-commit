# Fix for GUI apps not loading PATH correctly
export PATH=$PATH:/usr/local/bin:/opt/homebrew/bin

# Prevent infinite loop when amending
if [ "$SKIP_POST_COMMIT" = "1" ]; then
  exit 0
fi

cd "$(git rev-parse --show-toplevel)"

echo "🔄 Auto-incrementing version..."
node frontend/scripts/increment-version.js

echo "📝 Updating changelog..."
node frontend/scripts/update-changelog.js

git add frontend/src/version.ts Documentation/VERSION.md
SKIP_POST_COMMIT=1 git commit --amend --no-edit --no-verify

# Record demo video in background (non-blocking)
# Only runs if dev servers are up (frontend on :3000, backend on :3001)
if curl -sf http://localhost:3000 > /dev/null 2>&1 && curl -sf http://localhost:3001/api/health > /dev/null 2>&1; then
  DEMO_LOG="demo/demo-recording.log"
  echo "🎬 Triggering demo video recording in background (log: $DEMO_LOG)..."
  mkdir -p demo
  TSX_BIN="./backend/node_modules/.bin/tsx"
  if [ ! -x "$TSX_BIN" ]; then
    TSX_BIN="$(npx which tsx 2>/dev/null || echo tsx)"
  fi
  nohup "$TSX_BIN" demo/record-demo.ts > "$DEMO_LOG" 2>&1 &
  echo "🎬 Demo PID: $! — video will be saved to demo/demo.mp4"
else
  echo "⏭️  Skipping demo recording (dev servers not running)"
fi

# Deploy to AWS in background (non-blocking)
# Only runs if .env.deploy exists (contains server address and secrets)
ROOT="$(git rev-parse --show-toplevel)"
AWS_SCRIPT="$ROOT/aws.sh"
DEPLOY_ENV="$ROOT/.env.deploy"
DEPLOY_LOG="$ROOT/deploy.log"
if [ -f "$DEPLOY_ENV" ] && [ -f "$AWS_SCRIPT" ]; then
  echo "🚀 Deploying to AWS in background (log: deploy.log)..."
  nohup bash "$AWS_SCRIPT" > "$DEPLOY_LOG" 2>&1 &
  echo "🚀 Deploy PID: $! — streaming to deploy.log"
else
  echo "⏭️  Skipping AWS deploy (.env.deploy not found)"
fi
