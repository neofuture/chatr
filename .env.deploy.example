# Chatr — Deployment Configuration
# Copy this file to .env.deploy and fill in your values.
# .env.deploy is gitignored — your secrets stay local.

# ── SSH / Server ─────────────────────────────────────
# The SSH user@host for your EC2 instance
DEPLOY_SERVER=ubuntu@ec2-xx-xx-xx-xx.region.compute.amazonaws.com
# Path to your SSH private key (.pem file)
DEPLOY_KEY=./your-key.pem

# ── Domain ───────────────────────────────────────────
# Your domain name (DNS A records must point to the EC2 IP)
# Leave empty to use the raw EC2 IP for testing
DEPLOY_DOMAIN=example.com

# ── Database (AWS RDS or any PostgreSQL) ─────────────
DB_HOST=your-db-host.region.rds.amazonaws.com
DB_NAME=chatr
DB_USER=chatr_user
DB_PASSWORD=your-database-password

# ── Redis (AWS ElastiCache or any Redis) ─────────────
REDIS_HOST=your-redis-host.region.cache.amazonaws.com

# ── Auth ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-at-least-32-characters

# ── AWS S3 (file storage) ───────────────────────────
S3_BUCKET=your-s3-bucket-name
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ── OpenAI (optional — powers Luna AI chatbot) ──────
OPENAI_API_KEY=sk-your-openai-key

# ── Dashboard ────────────────────────────────────────
# Password to protect the dashboard test runner in production
DASHBOARD_TEST_PASSWORD=your-dashboard-password

# ── Support ──────────────────────────────────────────
# Email of the user account that handles widget support chats
SUPPORT_AGENT_EMAIL=you@example.com
